# Cloudflare R2 storage credentials.
# Create a bucket + API token at https://dash.cloudflare.com → R2.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=edu-research-data
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com

# Free API keys for federal sources.
# All are free, instant signup, public:
#   BEA:    https://apps.bea.gov/API/signup/
#   BLS:    https://data.bls.gov/registrationEngine/
#   Census: https://api.census.gov/data/key_signup.html
#   NOAA:   https://www.ncdc.noaa.gov/cdo-web/token
#   FTM:    https://www.followthemoney.org/our-data/apis/
BEA_API_KEY=
BLS_API_KEY=
CENSUS_API_KEY=
NOAA_TOKEN=
FTM_API_KEY=
